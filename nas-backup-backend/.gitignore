# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
*.coverprofile
coverage.txt

# Go workspace file
go.work

# Dependency directories
vendor/

# Build output
/nas-backup
/build/
/dist/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Database files
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Data directory (runtime data)
/data/

# Configuration files with sensitive data
config.yaml

# Logs
*.log

# Temporary files
*.tmp
*.bak
*.cache

# Allow example files
!config.yaml.example
!data/rclone.conf.example
