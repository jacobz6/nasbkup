# =============================================================================
# Docker 构建排除规则
# 减小构建上下文，加快构建速度
# =============================================================================

# ---- Git / VCS ----
.git
.gitignore
.gitattributes

# ---- 文档 (非构建必需) ----
*.md
!nas-backup-backend/README.md
!nas-backup-frontend/README.md
docs/

# ---- IDE / 编辑器 ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- 操作系统文件 ----
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# ---- 环境变量 / 密钥 (绝不能进入镜像) ----
.env
.env.*
*.pem
*.key
data/
*.db
*.db-journal
*.db-wal
*.db-shm

# ---- Docker 自身文件 ----
Dockerfile
docker-compose.yml
docker-compose.*.yml
.dockerignore

# ---- 测试 / 调试产物 ----
coverage/
*.test
*.out
profile
debug/

# ---- 前端构建产物 (Dockerfile 中独立构建) ----
nas-backup-frontend/dist/
nas-backup-frontend/node_modules/

# ---- 后端构建产物 (Dockerfile 中独立编译) ----
nas-backup-backend/nas-backup
nas-backup-backend/data/
nas-backup-backend/config.yaml

# ---- 测试脚本 / 临时数据 ----
nas_file_generator.py
DEPLOYMENT_testenv.md
*.tmp
*.temp
